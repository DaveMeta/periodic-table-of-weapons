---
import BaseLayout from '../../layouts/BaseLayout.astro';
import WeaponCard from '../../components/WeaponCard.astro';
import { epochs } from '../../data/weapons';
import type { GetStaticPaths } from 'astro';

export const getStaticPaths: GetStaticPaths = () => {
  return epochs.map((epoch) => ({
    params: { slug: epoch.slug },
    props: { epoch },
  }));
};

const { epoch } = Astro.props;

const currentIndex = epochs.findIndex((e) => e.id === epoch.id);
const prevEpoch = currentIndex > 0 ? epochs[currentIndex - 1] : null;
const nextEpoch = currentIndex < epochs.length - 1 ? epochs[currentIndex + 1] : null;
---

<BaseLayout
  title={epoch.name}
  description={`Explore the weapons of the ${epoch.name} (${epoch.period}). ${epoch.weapons.length} historical weapons cataloged with detailed illustrations.`}
  ogImage={epoch.headerImage}
>
  <!-- Hero -->
  <section class="relative min-h-[50vh] flex items-end overflow-hidden">
    <div class="absolute inset-0">
      <img
        src={epoch.headerImage}
        alt={epoch.name}
        class="w-full h-full object-cover"
      />
      <div class="absolute inset-0 bg-gradient-to-t from-navy-950 via-navy-950/60 to-navy-950/20"></div>
    </div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-12 pt-32 w-full">
      <a href="/#epochs" class="text-sm text-accent hover:text-accent-light transition-colors mb-4 inline-block">
        &larr; All Epochs
      </a>
      <p class="text-xs font-heading font-bold uppercase tracking-[0.3em] text-accent mb-3">
        {epoch.period}
      </p>
      <h1 class="text-4xl sm:text-5xl md:text-6xl font-heading font-black text-cream mb-4">
        {epoch.name}
      </h1>
      <p class="text-xl text-cream/70 max-w-2xl">
        {epoch.subtitle}
      </p>
    </div>
  </section>

  <!-- Description -->
  <section class="py-16">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <p class="text-lg text-cream/70 leading-relaxed">
        {epoch.description}
      </p>
    </div>
  </section>

  <!-- Weapons Grid -->
  <section class="pb-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-center gap-4 mb-8">
        <h2 class="text-2xl font-heading font-bold text-cream whitespace-nowrap">
          Weapons of Note
        </h2>
        <div class="h-px flex-1 bg-navy-700/50"></div>
        <span class="text-sm text-cream/40">{epoch.weapons.length} weapons</span>
      </div>
      <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 xl:grid-cols-6 gap-4 stagger-children">
        {epoch.weapons.map((weapon) => (
          <WeaponCard id={weapon.id} name={weapon.name} />
        ))}
      </div>
    </div>
  </section>

  <!-- Navigation -->
  <section class="py-12 bg-navy-900 border-t border-navy-700/30">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-center justify-between">
        {prevEpoch ? (
          <a
            href={`/epochs/${prevEpoch.slug}`}
            class="group flex items-center gap-3 text-cream/60 hover:text-accent transition-colors"
          >
            <span class="text-2xl">&larr;</span>
            <div>
              <span class="text-xs font-heading uppercase tracking-wider text-cream/40">Previous</span>
              <span class="block font-heading font-bold">{prevEpoch.name}</span>
            </div>
          </a>
        ) : <div></div>}
        {nextEpoch ? (
          <a
            href={`/epochs/${nextEpoch.slug}`}
            class="group flex items-center gap-3 text-cream/60 hover:text-accent transition-colors text-right"
          >
            <div>
              <span class="text-xs font-heading uppercase tracking-wider text-cream/40">Next</span>
              <span class="block font-heading font-bold">{nextEpoch.name}</span>
            </div>
            <span class="text-2xl">&rarr;</span>
          </a>
        ) : <div></div>}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 bg-navy-900">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <p class="text-cream/60 mb-4">All {epoch.weapons.length} weapons from the {epoch.name} appear on the poster.</p>
      <a
        href="/poster"
        class="inline-block px-8 py-3 bg-accent text-navy-950 font-heading font-bold rounded-lg hover:bg-accent-light transition-colors"
      >
        Get the Poster
      </a>
    </div>
  </section>
</BaseLayout>
