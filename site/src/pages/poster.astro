---
import BaseLayout from '../layouts/BaseLayout.astro';
import EmailSignup from '../components/EmailSignup.astro';
import { totalWeapons } from '../data/weapons';

const productSchema = {
  "@context": "https://schema.org",
  "@type": "Product",
  "name": "The Periodic Table of Weapons Poster",
  "image": "https://periodictableofweapons.com/images/poster/poster.jpg",
  "description": `A 36x24 inch illustrated poster cataloging ${totalWeapons} historical weapons across five epochs of human warfare. Printed on 14pt glossy cover stock.`,
  "brand": {
    "@type": "Brand",
    "name": "Verge Studios"
  },
  "offers": {
    "@type": "Offer",
    "priceCurrency": "USD",
    "availability": "https://schema.org/OutOfStock",
    "url": "https://periodictableofweapons.com/poster"
  }
};
---

<BaseLayout
  title="The Poster"
  description={`The Periodic Table of Weapons poster: ${totalWeapons} illustrated weapons across five epochs. 36x24 inches on premium glossy stock. Order yours today.`}
  ogImage="/images/poster/poster.jpg"
  ogType="product"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(productSchema)} />
  </Fragment>

  <!-- Hero -->
  <section class="py-20 bg-navy-900">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-start">
        <!-- Poster Images -->
        <div class="space-y-6">
          <img
            src="/images/poster/poster.jpg"
            alt="The Periodic Table of Weapons poster"
            class="rounded-lg shadow-2xl border border-navy-700/30 w-full"
          />
        </div>

        <!-- Product Details -->
        <div class="lg:sticky lg:top-24">
          <p class="text-xs font-heading font-bold uppercase tracking-[0.3em] text-accent mb-4">
            Illustrated Poster
          </p>
          <h1 class="text-3xl sm:text-4xl font-heading font-black text-cream mb-6">
            The Periodic Table of Weapons
          </h1>
          <p class="text-cream/70 leading-relaxed mb-6">
            {totalWeapons} weapons illustrated and organized into a periodic table. Stone age through modern firearms, five epochs of how people have fought and killed each other.
          </p>

          <div class="bg-navy-800 rounded-lg p-6 border border-navy-700/40 mb-8">
            <h3 class="font-heading font-bold text-cream mb-4">Specifications</h3>
            <dl class="space-y-3 text-sm">
              <div class="flex justify-between">
                <dt class="text-cream/50">Dimensions</dt>
                <dd class="text-cream font-bold">36" x 24"</dd>
              </div>
              <div class="h-px bg-navy-700/30"></div>
              <div class="flex justify-between">
                <dt class="text-cream/50">Paper Stock</dt>
                <dd class="text-cream font-bold">14pt Glossy (AQ) Cover</dd>
              </div>
              <div class="h-px bg-navy-700/30"></div>
              <div class="flex justify-between">
                <dt class="text-cream/50">Weapons Cataloged</dt>
                <dd class="text-cream font-bold">{totalWeapons}</dd>
              </div>
              <div class="h-px bg-navy-700/30"></div>
              <div class="flex justify-between">
                <dt class="text-cream/50">Epochs Covered</dt>
                <dd class="text-cream font-bold">5</dd>
              </div>
              <div class="h-px bg-navy-700/30"></div>
              <div class="flex justify-between">
                <dt class="text-cream/50">Artwork</dt>
                <dd class="text-cream font-bold">Custom Hand-Illustrated</dd>
              </div>
            </dl>
          </div>

          <div class="bg-navy-800/60 rounded-lg p-6 border border-navy-700/40 mb-4">
            <p class="font-heading font-bold text-cream mb-2">Currently Reprinting</p>
            <p class="text-sm text-cream/60 leading-relaxed">
              The poster is currently being reprinted and will be available again soon. For inquiries about pricing, bulk orders, or availability, get in touch.
            </p>
          </div>
          <a
            href="mailto:hello@periodictableofweapons.com"
            class="block w-full px-8 py-4 bg-accent text-navy-950 font-heading font-bold text-lg rounded-lg hover:bg-accent-light transition-colors text-center"
          >
            Email Us for More Information
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Email Signup -->
  <EmailSignup />

  <!-- What's on the Poster -->
  <section class="py-20">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl font-heading font-bold text-cream mb-6">What is on the Poster</h2>
      <p class="text-cream/70 leading-relaxed mb-8">
        {totalWeapons} weapons sorted into five historical epochs, each one custom illustrated for the poster. Fists, thrown stones, bronze swords, siege engines, automatic firearms -- the whole ugly progression.
      </p>
      <a
        href="/#epochs"
        class="inline-block px-6 py-3 border border-cream/30 text-cream font-heading font-bold rounded-lg hover:border-accent hover:text-accent transition-colors"
      >
        Browse All Epochs
      </a>
    </div>
  </section>
</BaseLayout>
