---
import BaseLayout from '../../layouts/BaseLayout.astro';
import WeaponCard from '../../components/WeaponCard.astro';
import { weaponCategories } from '../../data/weapon-categories';
import { epochs } from '../../data/weapons';
import { weaponDetails } from '../../data/weapon-details';
import type { GetStaticPaths } from 'astro';

export const getStaticPaths: GetStaticPaths = () => {
  return weaponCategories.map((cat) => ({
    params: { slug: cat.slug },
    props: { category: cat },
  }));
};

const { category } = Astro.props;

// Build weapon data with epoch info for each weapon in this category
const weaponsWithEpoch = category.weaponIds
  .map((id) => {
    for (const epoch of epochs) {
      const weapon = epoch.weapons.find((w) => w.id === id);
      if (weapon) {
        return { weapon, epoch, detail: weaponDetails[id] };
      }
    }
    return null;
  })
  .filter(Boolean) as { weapon: any; epoch: any; detail: any }[];

const siteUrl = 'https://periodictableofweapons.com';

const breadcrumbs = [
  { name: 'Home', url: `${siteUrl}/` },
  { name: 'Weapon Types', url: `${siteUrl}/types/` },
  { name: category.name, url: `${siteUrl}/types/${category.slug}/` },
];

const collectionSchema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": category.title,
  "description": category.seoDescription,
  "url": `${siteUrl}/types/${category.slug}/`,
  "mainEntity": {
    "@type": "ItemList",
    "numberOfItems": weaponsWithEpoch.length,
    "itemListElement": weaponsWithEpoch.map((entry, i) => ({
      "@type": "ListItem",
      "position": i + 1,
      "name": entry.weapon.name,
      "url": `${siteUrl}/weapons/${entry.weapon.id}/`,
    })),
  },
};
---

<BaseLayout
  title={category.title}
  description={category.seoDescription}
  breadcrumbs={breadcrumbs}
>
  <script type="application/ld+json" set:html={JSON.stringify(collectionSchema)} />

  <!-- Header -->
  <section class="py-12 md:py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

      <!-- Breadcrumbs -->
      <nav class="mb-8 text-sm font-heading" aria-label="Breadcrumb">
        <ol class="flex items-center gap-2 text-cream/40">
          <li><a href="/" class="hover:text-accent transition-colors">Home</a></li>
          <li class="text-cream/20">/</li>
          <li><a href="/types" class="hover:text-accent transition-colors">Weapon Types</a></li>
          <li class="text-cream/20">/</li>
          <li class="text-cream/60">{category.name}</li>
        </ol>
      </nav>

      <div class="max-w-3xl">
        <p class="text-xs font-heading font-bold uppercase tracking-[0.25em] text-accent/80 mb-4">
          {weaponsWithEpoch.length} weapons cataloged
        </p>
        <h1 class="text-3xl sm:text-4xl lg:text-5xl font-heading font-black text-cream mb-6 leading-tight">
          {category.title}
        </h1>
        <p class="text-lg text-cream/60 leading-relaxed">
          {category.intro}
        </p>
      </div>
    </div>
  </section>

  <!-- Weapons List -->
  <section class="pb-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-center gap-4 mb-10">
        <h2 class="text-2xl font-heading font-bold text-cream whitespace-nowrap">
          The {category.name}
        </h2>
        <div class="h-px flex-1 bg-navy-700/50"></div>
      </div>

      <div class="space-y-12">
        {weaponsWithEpoch.map((entry) => (
          <article class="grid grid-cols-1 md:grid-cols-[200px_1fr] lg:grid-cols-[280px_1fr] gap-6 md:gap-8">
            <!-- Thumbnail -->
            <a href={`/weapons/${entry.weapon.id}`} class="group block">
              <div class="aspect-square rounded-lg overflow-hidden bg-navy-800 border border-navy-700/40 group-hover:border-accent/40 transition-colors">
                <img
                  src={`/images/squares/${entry.weapon.id}.jpg`}
                  alt={entry.weapon.name}
                  class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
                  loading="lazy"
                  decoding="async"
                />
              </div>
            </a>

            <!-- Details -->
            <div class="flex flex-col justify-center">
              <a
                href={`/epochs/${entry.epoch.slug}`}
                class="text-xs font-heading font-bold uppercase tracking-[0.2em] text-accent/60 hover:text-accent transition-colors mb-2 inline-block w-fit"
              >
                {entry.epoch.name} &middot; {entry.detail?.era || entry.epoch.period}
              </a>
              <h3 class="text-2xl font-heading font-bold text-cream mb-2">
                <a href={`/weapons/${entry.weapon.id}`} class="hover:text-accent transition-colors">
                  {entry.weapon.name}
                </a>
              </h3>
              {entry.detail && (
                <>
                  <p class="text-cream/60 leading-relaxed mb-3 line-clamp-3">
                    {entry.detail.description.slice(0, 250)}...
                  </p>
                  <div class="flex flex-wrap gap-x-6 gap-y-1 text-xs font-heading text-cream/40">
                    <span><span class="text-accent/50">Type:</span> {entry.detail.type}</span>
                    <span><span class="text-accent/50">Origin:</span> {entry.detail.origin}</span>
                  </div>
                  <a
                    href={`/weapons/${entry.weapon.id}`}
                    class="mt-3 text-sm font-heading text-accent/70 hover:text-accent transition-colors inline-block w-fit"
                  >
                    Read full history &rarr;
                  </a>
                </>
              )}
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- Other Categories -->
  <section class="py-16 bg-navy-900/50 border-t border-navy-700/20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl font-heading font-bold text-cream mb-8">Explore Other Weapon Types</h2>
      <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-4">
        {weaponCategories
          .filter((c) => c.slug !== category.slug)
          .map((c) => (
            <a
              href={`/types/${c.slug}`}
              class="group block p-4 bg-navy-800/50 rounded-lg border border-navy-700/30 hover:border-accent/40 transition-colors"
            >
              <h3 class="font-heading font-bold text-cream group-hover:text-accent transition-colors text-sm mb-1">
                {c.name}
              </h3>
              <p class="text-xs text-cream/40">{c.weaponIds.length} weapons</p>
            </a>
          ))}
      </div>
    </div>
  </section>

  <!-- Poster CTA -->
  <section class="py-16 bg-navy-900">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <p class="text-cream/60 mb-2 text-sm font-heading uppercase tracking-wider">54 Weapons. Five Epochs. One Poster.</p>
      <p class="text-cream/40 mb-6">All {weaponsWithEpoch.length} {category.name.toLowerCase()} are featured on the poster.</p>
      <a
        href="/poster"
        class="inline-block px-8 py-3 bg-accent text-navy-950 font-heading font-bold rounded-lg hover:bg-accent-light transition-colors"
      >
        Get the Poster
      </a>
    </div>
  </section>
</BaseLayout>
